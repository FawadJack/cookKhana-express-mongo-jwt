<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CookKhana!</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <nav>
      <div class="logo">
        <h1>CookKhana</h1>
      </div>
      <ul>
        <li><a href="/recipe">Add Recipe</a></li>
      </ul>
    </nav>
    <div class="container">
      <div class="box">
        <% if (recipes.length > 0) { %> <% recipes.forEach(item => { %>

        <div class="card">
          <h2><%= item.title %></h2>

          <div id="displaysteps"><%- item.detail %></div>

          <form action="/postDelete/<%= item._id %>" method="POST">
            <button type="submit">Delete</button>
          </form>
          <a href="/updatePost/<%= item._id %>">Update</a>
        </div>

        <% }) %> <% } else { %>

        <h2><%= error %></h2>

        <% } %>
      </div>
    </div>
  </body>
</html>
