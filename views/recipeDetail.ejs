<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CookKhana!</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="shortcut icon" href="/image/fav.png" type="image/x-icon">
</head>


<body>
    <nav>
        <div class="logo">
            <img src="/image/logo.png" alt="logo" class="logoIcon">
            <h1>CookKhana</h1>
          </div>
        <ul>
            <li><a href="/">Home</a></li>|
            <li><a href="/myrecipes">My post</a></li> |
            <li><a href="/recipe">Add Recipe</a></li> |
            <form action="/logout" method="POST">
                <button type="submit">Logout</button>
            </form>

        </ul>
    </nav>
    <div class="container">
        <div class="detailBox">
      
          <% if(recipe) { %>
      
            <div class="card">
      
              <h2>
                <%= recipe.author %>
              </h2>
      
              <h2>
                <%= recipe.title %>
              </h2>
      
              <div id="displaysteps">
                <%- recipe.detail %>
              </div>
      
            </div>
      
          <% } else { %>
      
            <h2>
              <%= error %>
            </h2>
      
          <% } %>
      
        </div>
      </div>
</body>
</html>